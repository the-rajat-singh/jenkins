pipeline {
    agent none
    environment {
        IMAGE = "therajatsingh/quick-task-app"
        TAG = "${BUILD_NUMBER}"
        AWS_DEFAULT_REGION = "ap-south-1"
    }
    stages {
        stage('Checkout') {
            agent { label 'linux' }
            steps {
                checkout scm
            }
        }
        
        stage('Build Docker Image') {
            agent { label 'linux' }
            steps {
                sh '''
                    docker build -t $IMAGE:$TAG .
                    docker tag $IMAGE:$TAG $IMAGE:latest
                '''
            }
        }
        
        stage('Login & Push (AWS SM - Secure)') {
            agent { label 'linux' }
            steps {
                sh '''
                    set +x
                    
                    SECRET=$(aws secretsmanager get-secret-value \
                        --secret-id dockerhub-creds \
                        --region ap-south-1 \
                        --query SecretString \
                        --output text)
                    
                    DOCKER_USER=$(echo $SECRET | jq -r '.Username')
                    DOCKER_PASS=$(echo $SECRET | jq -r '.Password')
                    
                    echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                    
                    set -x
                    docker push $IMAGE:$TAG
                    docker push $IMAGE:latest
                    docker logout
                    set +x
                    
                    unset SECRET
                    unset DOCKER_USER
                    unset DOCKER_PASS
                '''
            }
        }
        
        stage('Deploy to Server') {
            agent { label 'linux' }
            steps {
                sshagent(['ssh-new-key']) {
                    sh '''
                        ssh -o StrictHostKeyChecking=no ubuntu@13.126.58.170 << 'EOFSH'
docker pull therajatsingh/quick-task-app:''' + env.TAG + '''
docker stop task-app || true
docker rm task-app || true
docker run -d -p 80:80 --name task-app therajatsingh/quick-task-app:''' + env.TAG + '''
docker ps | grep task-app
EOFSH
                    '''
                }
            }
        }
    }
    
    post {
        success {
            echo "✅ Pipeline Success! Image pushed and deployed"
        }
        failure {
            echo "❌ Pipeline failed!"
        }
    }
}
