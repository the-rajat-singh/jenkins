pipeline {
    agent none

    environment {
        IMAGE = "therajatsingh/quick-task-app"
        TAG = "${BUILD_NUMBER}"
        AWS_DEFAULT_REGION = "ap-south-1"
    }

    stages {

        stage('Checkout') {
            agent { label 'linux-agent' }
            steps {
                checkout scm
            }
        }

        stage('Build Docker Image') {
            agent { label 'linux' }
            steps {
                sh '''
                docker build -t $IMAGE:$TAG .
                '''
            }
        }

        stage('Login & Push (AWS SM + Masked)') {
            agent { label 'linux' }
            steps {
                script {

                    // 🔐 Fetch secret securely
                    def secret = sh(
                        script: '''
                        aws secretsmanager get-secret-value \
                        --secret-id dockerhub-creds \
                        --query SecretString \
                        --output text
                        ''',
                        returnStdout: true
                    ).trim()

                    // 🔍 Extract values
                    def DOCKER_USER = sh(
                        script: "echo '${secret}' | jq -r .Username",
                        returnStdout: true
                    ).trim()

                    def DOCKER_PASS = sh(
                        script: "echo '${secret}' | jq -r .Password",
                        returnStdout: true
                    ).trim()

                    // 🛡️ Mask password in logs
                    wrap([$class: 'MaskPasswordsBuildWrapper',
                        varPasswordPairs: [[var: 'DOCKER_PASS', password: DOCKER_PASS]]
                    ]) {

                        sh """
                        set +x   # 🔥 disable command echo

                        echo \$DOCKER_PASS | docker login -u ${DOCKER_USER} --password-stdin

                        docker push ${IMAGE}:${TAG}

                        set -x
                        """
                    }
                }
            }
        }

        stage('Deploy to Server') {
            agent { label 'linux' }
            steps {
                sshagent(['server-ssh-key']) {
                    sh '''
                    set +x

                    ssh -o StrictHostKeyChecking=no ubuntu@13.126.58.170 << EOF

                    docker pull $IMAGE:$TAG

                    docker stop task-app || true
                    docker rm task-app || true

                    docker run -d -p 80:80 --name task-app $IMAGE:$TAG

                    EOF
                    '''
                }
            }
        }
    }
}
