// Fixed Jenkinsfile with proper Docker image references

pipeline {
    agent any
    
    environment {
        DOCKER_IMAGE = "therajatsingh/quick-task-app"
        DOCKER_REGISTRY = "docker.io"
        AWS_REGION = "ap-south-1"
        DEPLOY_SERVER = "13.126.58.170"
        DEPLOY_USER = "ubuntu"
    }
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        
        stage('Build Docker Image') {
            steps {
                script {
                    sh '''
                        docker build -t ${DOCKER_IMAGE}:${BUILD_NUMBER} .
                        docker tag ${DOCKER_IMAGE}:${BUILD_NUMBER} ${DOCKER_IMAGE}:latest
                    '''
                }
            }
        }
        
        stage('Login & Push (AWS SM - Secure)') {
            steps {
                script {
                    sh '''
                        set +x
                        docker login -u $DOCKER_USER -p $DOCKER_PASSWORD
                        set -x
                        docker push ${DOCKER_IMAGE}:${BUILD_NUMBER}
                        docker push ${DOCKER_IMAGE}:latest
                    '''
                }
            }
        }
        
        stage('Deploy to Server') {
            steps {
                sshagent(['ubuntu']) {
                    sh '''
                        ssh -o StrictHostKeyChecking=no ${DEPLOY_USER}@${DEPLOY_SERVER} << 'EOFSH'
                            # Pull the latest image
                            docker pull ${DOCKER_IMAGE}:${BUILD_NUMBER}
                            
                            # Stop and remove old container if exists
                            docker stop quick-task-app || true
                            docker rm quick-task-app || true
                            
                            # Run new container
                            docker run -d \
                                --name quick-task-app \
                                -p 80:80 \
                                -p 443:443 \
                                ${DOCKER_IMAGE}:${BUILD_NUMBER}
                            
                            # Verify container is running
                            docker ps | grep quick-task-app || (echo "Container failed to start" && exit 1)
                        EOFSH
                    '''
                }
            }
        }
    }
    
    post {
        success {
            echo "Pipeline executed successfully!"
            echo "Image: ${DOCKER_IMAGE}:${BUILD_NUMBER}"
            echo "Deployed to: ${DEPLOY_USER}@${DEPLOY_SERVER}"
        }
        failure {
            echo "Pipeline failed! Check logs above for details"
        }
        always {
            cleanWs()
        }
    }
}
