pipeline {
    agent none

    environment {
        IMAGE = "therajatsingh/quick-task-app"
        TAG = "${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            agent { label 'linux-agent' }
            steps {
                checkout scm
            }
        }

        stage('Build Docker Image') {
            agent { label 'docker-agent2' }   // 👈 IMPORTANT
            steps {
                sh 'docker build -t $IMAGE:$TAG .'
            }
        }

        stage('Push Image') {
            agent { label 'docker-agent2' }   // 👈 IMPORTANT
            steps {
                sh 'docker push $IMAGE:$TAG'
            }
        }

        stage('Deploy') {
            agent { label 'linux-agent' }
            steps {
                sshagent(['server-ssh-key']) {
                    sh '''
                    ssh ubuntu@13.126.58.170 << EOF
                    docker pull $IMAGE:$TAG
                    docker stop task-app || true
                    docker rm task-app || true
                    docker run -d -p 80:80 --name task-app $IMAGE:$TAG
                    EOF
                    '''
                }
            }
        }
    }
}
